  triggerAfterLevelIndex: 5
  pages:
  - frame0:
      sprite: {fileID: 21300000, guid: 3cf5f6c3f3a999e41bfb50d862a99daf, type: 3}
      showTextPlate: 0
      frameText: 
    frame1:
      sprite: {fileID: 21300000, guid: ab4a74e4c8d3fdf4f98224eb186dc0da, type: 3}
      showTextPlate: 1
      frameText: "\u041D\u0438\u043A, \u0442\u0432\u043E\u044E \u043C\u0430\u0442\u044C!
        \u0422\u044B \u0432\u0440\u0435\u043C\u044F \u0432\u0438\u0434\u0435\u043B?
        \u0422\u044B \u043E\u043F\u044F\u0442\u044C \u0432\u0441\u044E \u043D\u043E\u0447\u044C
        \u0433\u0440\u043E\u0431\u0438\u043B \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435
        \u0437\u0430 \u0441\u0432\u043E\u0438\u043C \u043A\u043E\u043C\u043F\u043E\u043C?!"
    frame2:
      sprite: {fileID: 21300000, guid: 9498718465271504688194f5e259001b, type: 3}
      showTextPlate: 1
      frameText: "\u0428\u0430\u0440\u043B\u0438, \u043F\u0440\u0438\u0442\u043E\u0440\u043C\u043E\u0437\u0438...
        \u041F\u0440\u043E\u0441\u0442\u043E \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0438
        \u043D\u0430 \u044D\u043A\u0440\u0430\u043D. \u0422\u0430\u043C \u043F\u043B\u044E\u0441
        \u043F\u044F\u0442\u044C\u0441\u043E\u0442 \u0434\u043E\u043B\u043B\u0430\u0440\u043E\u0432.
        \u041F\u044F\u0442\u044C\u0441\u043E\u0442!"
  - frame0:
      sprite: {fileID: 21300000, guid: a929e3e00db294d47bd994e42761c260, type: 3}
      showTextPlate: 1
      frameText: "\u0421\u043A\u043E\u043B\u044C\u043A\u043E-\u0441\u043A\u043E\u043B\u044C\u043A\u043E?!
        \u041E\u0442\u043A\u0443\u0434\u0430?!\r\r\n\u041A\u0430\u043A \u0434\u0443\u043C\u0430\u0435\u0448\u044C...
        \u0442\u0430\u043C \u0435\u0441\u0442\u044C \u0435\u0449\u0435 \u0440\u0430\u0431\u043E\u0442\u0430?"
    frame1:
      sprite: {fileID: 21300000, guid: 29c4ce2a959a46d49921211835c8e199, type: 3}
      showTextPlate: 1
      frameText: "\u0414\u0430, \u043C\u0430\u043B\u044B\u0448\u043A\u0430. \u042F
        \u043F\u043E\u0441\u043F\u043B\u044E \u0447\u0430\u0441\u0430 \u0434\u0432\u0430
        \u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0443. \u0421\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0435
        \u0437\u0430\u0434\u0430\u043D\u0438\u0435 \u0441\u0442\u043E\u0438\u0442
        \u0448\u0442\u0443\u043A\u0443. \u041A\u043E\u0433\u0434\u0430 \u0442\u044B
        \u0432\u0435\u0440\u043D\u0435\u0448\u044C\u0441\u044F \u0441 \u0440\u0430\u0431\u043E\u0442\u044B,
        \u0443 \u043D\u0430\u0441 \u0431\u0443\u0434\u0443\u0442 \u0434\u0435\u043D\u044C\u0433\u0438
        \u0438 \u043D\u0430\u0441 \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u043D\u0435
        \u0432\u044B\u0441\u0435\u043B\u044F\u0442"
    frame2:
      sprite: {fileID: 21300000, guid: 69323f34d0cf42546b88c63ad523858a, type: 3}
      showTextPlate: 1
      frameText: "\u041C\u0438\u043B\u044B\u0439... \u0422\u044B \u0442\u043E\u043B\u044C\u043A\u043E
        \u043E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u044C\u043D\u043E \u043E\u0442\u0434\u043E\u0445\u043D\u0438,
        \u043E\u0431\u0435\u0449\u0430\u0439 \u043C\u043D\u0435. \u0410 \u044F \u043F\u043E\u0439\u0434\u0443
        \u0441\u043E\u0431\u0438\u0440\u0430\u0442\u044C\u0441\u044F"
  - frame0:
      sprite: {fileID: 21300000, guid: 24d46d02af6bd6043920cc55c44f13d1, type: 3}
      showTextPlate: 0
      frameText: 
    frame1:
      sprite: {fileID: 21300000, guid: d63dc21f6a93d5e4aad9dc1046070574, type: 3}
      showTextPlate: 1
      frameText: "\u041D\u0438\u043A? \u0422\u044B \u0437\u0434\u0435\u0441\u044C,
        \u0434\u0440\u0443\u0436\u0438\u0449\u0435?"
    frame2:
      sprite: {fileID: 21300000, guid: d2590ab1ed846664ab7c629d626d0686, type: 3}
      showTextPlate: 0
      frameText: 
  - frame0:
      sprite: {fileID: 21300000, guid: 168accfbcab8933448802821fa6e1440, type: 3}
      showTextPlate: 1
      frameText: "\u041F\u0430\u0442\u0440\u0438\u043A?!"
    frame1:
      sprite: {fileID: 21300000, guid: 490054cf4ee06dd408c7079a28bdb254, type: 3}
      showTextPlate: 1
      frameText: "\u0411\u043E\u0436\u0435, \u041D\u0438\u043A, \u0442\u044B \u0432\u044B\u0433\u043B\u044F\u0434\u0438\u0448\u044C
        \u043A\u0430\u043A \u043F\u043E\u043A\u043E\u0439\u043D\u0438\u043A. \u041B\u0438\u0437\u0430
        \u0432\u0441\u044F \u0438\u0437\u0432\u0435\u043B\u0430\u0441\u044C, \u0437\u0432\u043E\u043D\u0438\u0442
        \u043C\u043D\u0435 \u043A\u0430\u0436\u0434\u044B\u0439 \u0447\u0430\u0441.
        \u042F \u0440\u0435\u0448\u0438\u043B \u0437\u0430\u0435\u0445\u0430\u0442\u044C,
        \u043F\u0440\u043E\u0432\u0435\u0434\u0430\u0442\u044C. \u0422\u0430\u043A
        \u043A\u0430\u043A \u0434\u0435\u043B\u0430? \u0412\u0438\u0436\u0443, \u0447\u0442\u043E
        \u043D\u0435 \u043E\u0447\u0435\u043D\u044C"
    frame2:
      sprite: {fileID: 21300000, guid: b5327c501e7877342aee4b27261c535c, type: 3}
      showTextPlate: 1
      frameText: "\u0421\u043B\u0443\u0448\u0430\u0439, \u0430 \u0442\u044B \u0441\u043C\u043E\u0436\u0435\u0448\u044C
        \u0441\u0435\u0439\u0447\u0430\u0441 \u043E\u0442\u0434\u0430\u0442\u044C
        \u0445\u043E\u0442\u044C \u0447\u0442\u043E-\u0442\u043E \u043F\u043E \u0434\u043E\u043B\u0433\u0443?
        \u0415\u0441\u043B\u0438 \u043D\u0435\u0442 \u2014 \u043D\u0438\u0447\u0435\u0433\u043E
        \u0441\u0442\u0440\u0430\u0448\u043D\u043E\u0433\u043E, \u044F \u0432\u0441\u0435
        \u043F\u043E\u043D\u0438\u043C\u0430\u044E. \u041C\u043D\u0435 \u0432\u0435\u0434\u044C
        \u044D\u0442\u043E \u0442\u043E\u0436\u0435 \u0434\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442
        \u043D\u0435\u043F\u0440\u0438\u044F\u0442\u043D\u043E\u0441\u0442\u0438"
  - frame0:
      sprite: {fileID: 21300000, guid: 79bf4feaeaea7f242a1991dbba119cba, type: 3}
      showTextPlate: 1
      frameText: "\u041F\u0440\u043E\u0441\u0442\u0438, \u041F\u0430\u0442\u0440\u0438\u043A.
        \u0414\u0435\u043D\u0435\u0433 \u0441\u0435\u0439\u0447\u0430\u0441 \u043D\u0435\u0442.
        \u041D\u043E \u0441\u043A\u043E\u0440\u043E \u0432\u0441\u0451 \u043E\u0442\u0434\u0430\u043C,
        \u043E\u0431\u0435\u0449\u0430\u044E. \u041F\u0435\u0440\u0435\u0434\u0430\u0432\u0430\u0439
        \u041B\u0438\u0437\u0435... \u043F\u0440\u0438\u0432\u0435\u0442"
    frame1:
      sprite: {fileID: 21300000, guid: e2610491efb14c24192665c464a1553f, type: 3}
      showTextPlate: 1
      frameText: "\u041D\u0443, \u0441\u043C\u043E\u0442\u0440\u0438 \u0441\u0430\u043C,
        \u041D\u0438\u043A. \u041D\u0435 \u0437\u0430\u0442\u044F\u0433\u0438\u0432\u0430\u0439.
        \u041C\u044B \u0441 \u0442\u0432\u043E\u0435\u0439 \u0441\u0435\u0441\u0442\u0440\u043E\u0439
        \u0432\u043E\u043B\u043D\u0443\u0435\u043C\u0441\u044F \u0437\u0430 \u0442\u0435\u0431\u044F"
    frame2:
      sprite: {fileID: 21300000, guid: 1ae6fe4bf15dc214c92f5140b9ad9c99, type: 3}
      showTextPlate: 1
      frameText: "\u0423\u0435\u0431\u0430\u043D... \u0435\u0431\u0430\u043D\u044B\u0439
        \u0432 \u0440\u043E\u0442! \u0417\u043D\u0430\u0435\u0442 \u0436\u0435, \u0441\u0443\u043A\u0430,
        \u0447\u0442\u043E \u044F \u043D\u0430 \u043D\u0443\u043B\u0435. \u041A\u0430\u043A
        \u0441\u0435\u0441\u0442\u0440\u0430 \u0432\u043E\u043E\u0431\u0449\u0435
        \u0441 \u043D\u0438\u043C \u0443\u0436\u0438\u0432\u0430\u0435\u0442\u0441\u044F,
        \u0431\u043B\u044F\u0434\u044C? \u041A\u0430\u043A?!"
  - frame0:
      sprite: {fileID: 21300000, guid: c39fe0d096e39604f9673336c0bb2ee6, type: 3}
      showTextPlate: 1
      frameText: "\u0421\u0443\u043A\u0430 \u0441\u0443\u043A\u0430 \u0441\u0443\u043A\u0430!
        \u0414\u043E\u0441\u0442\u0430\u0442\u044C \u0434\u0435\u043D\u044C\u0433\u0438.
        \u041B\u044E\u0431\u043E\u0439 \u0446\u0435\u043D\u043E\u0439. \u041F\u0440\u044F\u043C\u043E
        \u0441\u0435\u0439\u0447\u0430\u0441"
    frame1:
      sprite: {fileID: 21300000, guid: ca73b9c3cd7af40418cf28a1541e4fa0, type: 3}
      showTextPlate: 1
      frameText: "\u041B\u0430\u0434\u043D\u043E. \u0425\u043E\u0447\u0435\u0448\u044C
        \u0434\u0435\u043D\u0435\u0433, \u041F\u0430\u0442\u0440\u0438\u043A? \u0411\u0443\u0434\u0443\u0442
        \u0442\u0435\u0431\u0435 \u0434\u0435\u043D\u044C\u0433\u0438. \u042F \u0432\u0435\u0440\u043D\u0443
        \u0432\u0441\u0451 \u0434\u043E \u0446\u0435\u043D\u0442\u0430, \u0443\u0440\u043E\u0434\u0435\u0446"
    frame2:
      sprite: {fileID: 21300000, guid: 7341a742eb5dfa742a9ed0251a7b0a38, type: 3}
      showTextPlate: 1
      frameText: "[\u0421\u0418\u0421\u0422\u0415\u041C\u0410]: \u0418\u041D\u0418\u0426\u0418\u0410\u041B\u0418\u0417\u0410\u0426\u0418\u042F
        \u0421\u0415\u041A\u0422\u041E\u0420A 2.\r.\r\n[\u041C\u041E\u0414\u0418\u0424\u0418\u041A\u0410\u0422\u041E\u0420\u042B]:
        \u0414\u041E\u0411\u0410\u0412\u041B\u0415\u041D\u0410 \u041E\u0421\u042C
        Z \r\n[\u041D\u0410\u0413\u0420\u0410\u0414\u0410 \u0417\u0410 \u041A\u041E\u041D\u0422\u0420\u0410\u041A\u0422]:
        1000 USDT.\r"
